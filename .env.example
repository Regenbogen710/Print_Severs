# Server
PRINT_SERVER_HOST=0.0.0.0
PRINT_SERVER_PORT=8000
PRINT_SERVER_WORKER_ENABLED=true

# Printer
PRINT_SERVER_PRINTER_NAME=Lenovo LJ2205
PRINT_SERVER_DRY_RUN=false

# Optional but recommended for reliable PDF printing on Windows.
# Example: C:\Program Files\SumatraPDF\SumatraPDF.exe
PRINT_SERVER_SUMATRA_PDF_PATH=

# Optional for doc/docx/rtf/txt printing.
# Example: C:\Program Files\LibreOffice\program\soffice.exe
PRINT_SERVER_LIBREOFFICE_PATH=

# Storage and upload limits
PRINT_SERVER_DATA_DIR=data
PRINT_SERVER_MAX_UPLOAD_MB=50
PRINT_SERVER_ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.bmp,.gif,.tif,.tiff,.doc,.docx,.rtf,.txt

# Access control
# Default mode allows localhost and private/LAN addresses only.
PRINT_SERVER_PUBLIC_ACCESS_ENABLED=false
PRINT_SERVER_PUBLIC_IP_WHITELIST=
PRINT_SERVER_TRUST_PROXY_HEADERS=false
PRINT_SERVER_TRUSTED_PROXY_IPS=

# Authentication
PRINT_SERVER_ADMIN_USERNAME=admin
PRINT_SERVER_ADMIN_PASSWORD=change-this-password
PRINT_SERVER_REQUIRE_AUTH_FOR_UPLOAD=false

# Print execution
PRINT_SERVER_PRINT_COMMAND_TIMEOUT_SECONDS=90
PRINT_SERVER_WORKER_POLL_SECONDS=2
